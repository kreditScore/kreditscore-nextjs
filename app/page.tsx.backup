  const handleFeatureClick = (featureName: string) => {
    setSelectedFeature(featureName);
    setIsModalOpen(true);
  };

  const handleLoanClick = (loanType: string) => {
    if (loanType === 'Personal Loan') {
      setShowPersonalLoanForm(true);
      setSelectedLoanType(loanType);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } else {
      setSelectedLoanType(loanType);
      setIsLoanFormOpen(true);
    }
  };

  const handleInputChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    setFormData({ ...formData, [e.target.name]: e.target.value });
  };

  const handleCityInputChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const value = e.target.value;
    setCityInput(value);

    if (value.length >= 2) {
      const filtered = indianCities.filter(city =>
        city.toLowerCase().includes(value.toLowerCase())
      ).slice(0, 10); // Show max 10 suggestions
      setFilteredCities(filtered);
      setShowCitySuggestions(true);
    } else {
      setShowCitySuggestions(false);
      setFilteredCities([]);
    }
  };

  const handleCitySelect = (city: string) => {
    setCityInput(city);
    setFormData({ ...formData, address: city });
    setShowCitySuggestions(false);
  };

  const handleCompanyInputChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const value = e.target.value;
    setCompanyInput(value);

    if (value.length >= 2) {
      const filtered = indianCompanies.filter(company =>
        company.toLowerCase().includes(value.toLowerCase())
      ).slice(0, 10); // Show max 10 suggestions
      setFilteredCompanies(filtered);
      setShowCompanySuggestions(true);
    } else {
      setShowCompanySuggestions(false);
      setFilteredCompanies([]);
    }
  };

  const handleCompanySelect = (company: string) => {
    setCompanyInput(company);
    setFormData({ ...formData, companyName: company });
    setShowCompanySuggestions(false);
  };

  // Close dropdown when clicking outside
  useEffect(() => {
    const handleClickOutside = (event: MouseEvent) => {
      const target = event.target as HTMLElement;
      if (!target.closest('.city-autocomplete')) {
        setShowCitySuggestions(false);
      }
      if (!target.closest('.company-autocomplete')) {
        setShowCompanySuggestions(false);
      }
    };

    document.addEventListener('mousedown', handleClickOutside);
    return () => {
      document.removeEventListener('mousedown', handleClickOutside);
    };
  }, []);

  const handleNext = () => {
    if (currentStep < 4) setCurrentStep(currentStep + 1);
  };

  const handlePrevious = () => {
    if (currentStep > 1) setCurrentStep(currentStep - 1);
  };

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    console.log('Form submitted:', formData);

    // Show success message
    setIsSubmitted(true);

    // Reset form after 3 seconds
    setTimeout(() => {
      setFormData({
        name: '',
        mobile: '',
        loanAmount: '',
        address: '',
        pan: '',
        dob: '',
        companyName: '',
        salary: ''
      });
      setCityInput('');
      setCompanyInput('');
      setCurrentStep(1);
      setIsSubmitted(false);
    }, 3000);
  };

  // 10 Loan Products - 2 rows of 5 (matching original HTML content)
  const loanProducts: LoanProduct[] = [
    {
      icon: CreditCard,
      title: "Personal Loan",
      features: ["Eligibility in 2 Min", "Money in 1 Day"],
      color: "from-blue-500 to-blue-600"
