                      <motion.div
                        initial={{ scale: 0 }}
                        animate={{ scale: [0, 1.2, 1] }}
                        transition={{
                          duration: 0.6,
                          ease: [0.34, 1.56, 0.64, 1],
                          times: [0, 0.6, 1]
                        }}
                        className="relative"
                      >
                        <CheckCircle2 className="w-20 h-20 text-white drop-shadow-2xl" />
                        <motion.div
                          initial={{ scale: 0, opacity: 0 }}
