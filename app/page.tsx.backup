                        />
                      </div>
                      <button className="w-full mt-4 py-4 bg-gradient-to-r from-[#00c9a7] to-[#00b894] text-white font-bold rounded-xl hover:shadow-lg transition-all duration-300">
                        Continue
                      </button>
                    </div>

                    {/* Mobile Number */}
                    <div className="pt-6 border-t">
                      <h3 className="text-lg font-semibold text-gray-700 mb-4">Provide your mobile number</h3>
                      <div className="relative">
                        <Phone className="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" />
                        <input
                          type="tel"
                          placeholder="Enter Your Mobile Number"
                          maxLength={10}
