                        transition={{
                          delay: 0.3,
                          duration: 0.5,
                          ease: "easeOut"
                        }}
                        className="text-center space-y-2"
                      >
                        <motion.h3
                          initial={{ scale: 0.8 }}
                          animate={{ scale: 1 }}
                          transition={{ delay: 0.4, duration: 0.3 }}
