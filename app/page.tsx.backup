// Types
interface LoanProduct {
  icon: any;
  title: string;
  features: string[];
  color: string;
}

interface Tool {
  icon: any;
  title: string;
  color: string;
}

interface Step {
  icon: any;
  title: string;
  description: string;
  color: string;
}

interface Reason {
  icon: any;
  title: string;
  description: string;
  gradient: string;
}

