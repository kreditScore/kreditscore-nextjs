NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Firebase Client (Browser Auth — Phone OTP + Google) ───────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Same Firebase web app values, server-only — used at runtime if NEXT_PUBLIC_* were empty at build (e.g. Vercel).
# Easiest on Vercel: one variable — paste the whole `firebaseConfig` object as a single-line JSON:
# FIREBASE_WEB_CONFIG_JSON={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}
FIREBASE_WEB_CONFIG_JSON=
# Or set these four (optional messaging sender id):
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_MESSAGING_SENDER_ID=

# ─── Firebase Admin (Server-side JWT verification) ─────────────────────────────
# Option A: Paste entire service-account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: Path to downloaded service-account .json file (local dev)
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# ─── Supabase / PostgreSQL (Data storage) ──────────────────────────────────────
# Use Supabase → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# Set to "true" for Supabase (they require TLS)
DATABASE_SSL=true

# ─── Optional integrations ─────────────────────────────────────────────────────
BANK_PARTNER_API_BASE_URL=
BANK_PARTNER_API_KEY=
